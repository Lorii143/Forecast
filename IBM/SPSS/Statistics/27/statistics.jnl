* Chart Builder.
GGRAPH
  /GRAPHDATASET NAME="graphdataset" VARIABLES=ANC Numberreached MISSING=LISTWISE REPORTMISSING=NO
  /GRAPHSPEC SOURCE=INLINE.
BEGIN GPL
  SOURCE: s=userSource(id("graphdataset"))
  DATA: ANC=col(source(s), name("ANC"))
  DATA: Numberreached=col(source(s), name("Numberreached"), unit.category())
  GUIDE: axis(dim(1), label("ANC"))
  GUIDE: axis(dim(2), label("Number reached"))
  GUIDE: text.title(label("Simple Line of Number reached by ANC"))
  ELEMENT: line(position(ANC*Numberreached), missing.wings())
END GPL.
* Chart Builder.
GGRAPH
  /GRAPHDATASET NAME="graphdataset" VARIABLES=Numberreached ANC MISSING=LISTWISE REPORTMISSING=NO
  /GRAPHSPEC SOURCE=INLINE.
BEGIN GPL
  SOURCE: s=userSource(id("graphdataset"))
  DATA: Numberreached=col(source(s), name("Numberreached"), unit.category())
  DATA: ANC=col(source(s), name("ANC"))
  GUIDE: axis(dim(1), label("Number reached"))
  GUIDE: axis(dim(2), label("ANC"))
  GUIDE: text.title(label("Simple Line of ANC by Number reached"))
  SCALE: linear(dim(2), include(0))
  ELEMENT: line(position(Numberreached*ANC), missing.wings())
END GPL.
* Chart Builder.
GGRAPH
  /GRAPHDATASET NAME="graphdataset" VARIABLES=Numberreached MEAN(ANC) MEAN(SBA) MEAN(Nutrition)
    MISSING=LISTWISE REPORTMISSING=NO
    TRANSFORM=VARSTOCASES(SUMMARY="#SUMMARY" INDEX="#INDEX")
  /GRAPHSPEC SOURCE=INLINE.
BEGIN GPL
  SOURCE: s=userSource(id("graphdataset"))
  DATA: Numberreached=col(source(s), name("Numberreached"), unit.category())
  DATA: SUMMARY=col(source(s), name("#SUMMARY"))
  DATA: INDEX=col(source(s), name("#INDEX"), unit.category())
  GUIDE: axis(dim(1), label("Number reached"))
  GUIDE: axis(dim(2), label("Mean"))
  GUIDE: legend(aesthetic(aesthetic.color.interior), label(""))
  GUIDE: text.title(label("Multiple Line Mean of ANC, Mean of SBA, Mean of Nutrition  by Number ",
    "reached..."))
  SCALE: linear(dim(2), include(0))
  SCALE: cat(aesthetic(aesthetic.color.interior), include(
"0", "1", "2"))
  ELEMENT: line(position(Numberreached*SUMMARY), color.interior(INDEX), missing.wings())
END GPL.
