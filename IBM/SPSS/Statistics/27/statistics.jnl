GGRAPH
  /GRAPHDATASET NAME="graphdataset" VARIABLES=
    @21.IfinHealthfacilityhowmanytimesdidyouattendtheANCclinic[name=
    "_21_IfinHealthfacilityhowmanytimesdidyouattendtheANCclinic"] COUNT()[name="COUNT"]
    MISSING=LISTWISE REPORTMISSING=NO
  /GRAPHSPEC SOURCE=INLINE
  /COLORCYCLE COLOR1(17,146,232), COLOR2(0,93,93), COLOR3(159,24,83), COLOR4(250,77,86),
    COLOR5(87,4,8), COLOR6(25,128,56), COLOR7(0,45,156), COLOR8(238,83,139), COLOR9(178,134,0),
    COLOR10(0,157,154), COLOR11(1,39,73), COLOR12(138,56,0), COLOR13(165,110,255),
    COLOR14(236,230,208), COLOR15(69,70,71), COLOR16(92,202,136), COLOR17(208,83,52),
    COLOR18(204,127,228), COLOR19(225,188,29), COLOR20(237,75,75), COLOR21(28,205,205),
    COLOR22(92,113,72), COLOR23(225,139,14), COLOR24(9,38,114), COLOR25(90,100,94), COLOR26(155,0,0),
    COLOR27(207,172,227), COLOR28(150,145,145), COLOR29(63,235,124), COLOR30(105,41,196)
  /FRAME OUTER=NO INNER=NO
  /GRIDLINES XAXIS=NO YAXIS=YES
  /STYLE GRADIENT=NO.
BEGIN GPL
  SOURCE: s=userSource(id("graphdataset"))
  DATA: IfinHealthfacilityhowmanytimesdidyouattendtheANCclinic=col(source(s),
    name("_21_IfinHealthfacilityhowmanytimesdidyouattendtheANCclinic"), unit.category())
  DATA: COUNT=col(source(s), name("COUNT"))
  COORD: polar.theta(startAngle(0))
  GUIDE: axis(dim(1), null())
  GUIDE: legend(aesthetic(aesthetic.color.interior), label("21. If in Health facility, how many ",
    "times did you attend the ANC clinic?"))
  GUIDE: text.title(label("Pie Chart Count of 21. If in Health facility, how many times did you ",
    "attend the ANC clinic?"))
  SCALE: linear(dim(1), dataMinimum(), dataMaximum())
  ELEMENT: interval.stack(position(summary.percent(COUNT))),
    color.interior(IfinHealthfacilityhowmanytimesdidyouattendtheANCclinic))
END GPL.
