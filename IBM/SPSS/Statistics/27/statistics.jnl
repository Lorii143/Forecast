  GUIDE: text.title(label("Simple Bar Count of 19. If yes in 18 above, whom did you see?"))
  SCALE: linear(dim(2), include(0))
  ELEMENT: interval(position(Ifyesin18abovewhomdidyousee*COUNT), shape.interior(shape.square))
END GPL.
