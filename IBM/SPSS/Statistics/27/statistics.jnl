    COLOR5(87,4,8), COLOR6(25,128,56), COLOR7(0,45,156), COLOR8(238,83,139), COLOR9(178,134,0),
    COLOR10(0,157,154), COLOR11(1,39,73), COLOR12(138,56,0), COLOR13(165,110,255),
    COLOR14(236,230,208), COLOR15(69,70,71), COLOR16(92,202,136), COLOR17(208,83,52),
    COLOR18(204,127,228), COLOR19(225,188,29), COLOR20(237,75,75), COLOR21(28,205,205),
    COLOR22(92,113,72), COLOR23(225,139,14), COLOR24(9,38,114), COLOR25(90,100,94), COLOR26(155,0,0),
    COLOR27(207,172,227), COLOR28(150,145,145), COLOR29(63,235,124), COLOR30(105,41,196)
  /FRAME OUTER=NO INNER=NO
  /GRIDLINES XAXIS=NO YAXIS=YES
  /STYLE GRADIENT=NO.
BEGIN GPL
  SOURCE: s=userSource(id("graphdataset"))
  DATA: Whichofthefollowingisyourcurrentprimarysourceoffunding=col(source(s),
    name("Whichofthefollowingisyourcurrentprimarysourceoffunding"), unit.category())
  DATA: Yeartheorganizationwasfounded=col(source(s), name("Yeartheorganizationwasfounded"),
    unit.category())
  GUIDE: axis(dim(1), label("Which of the following is your current primary source of funding?"))
  GUIDE: axis(dim(2), label("Year the organization was founded"))
  GUIDE: text.title(label("Simple Bar of Year the organization was founded by Which of the ",
    "following is your current primary source of funding?"))
  SCALE: cat(dim(2), include("1", "2", "3", "4"))
  ELEMENT: interval(position(Whichofthefollowingisyourcurrentprimarysourceoffunding*
    Yeartheorganizationwasfounded), shape.interior(shape.square))
END GPL.
