* Chart Builder.
GGRAPH
  /GRAPHDATASET NAME="graphdataset" VARIABLES=DATABASENO AGE MISSING=LISTWISE REPORTMISSING=NO
  /GRAPHSPEC SOURCE=INLINE.
BEGIN GPL
  SOURCE: s=userSource(id("graphdataset"))
  DATA: DATABASENO=col(source(s), name("DATABASENO"), unit.category())
  DATA: AGE=col(source(s), name("AGE"))
  DATA: id=col(source(s), name("$CASENUM"), unit.category())
  GUIDE: axis(dim(1), label("DATABASE NO"))
  GUIDE: axis(dim(2), label("AGE"))
  GUIDE: text.title(label("Simple Boxplot of AGE by DATABASE NO"))
  SCALE: cat(dim(1), include("1"))
  SCALE: linear(dim(2), include(0))
  ELEMENT: schema(position(bin.quantile.letter(DATABASENO*AGE)), label(id))
END GPL.
