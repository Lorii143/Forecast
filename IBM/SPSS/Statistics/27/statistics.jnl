  SCALE: cat(aesthetic(aesthetic.color.interior), include(
"1", "2", "3", "4"))
  ELEMENT: interval.stack(position(summary.percent(COUNT))), color.interior(MaritalStatus))
END GPL.
* Chart Builder.
GGRAPH
  /GRAPHDATASET NAME="graphdataset" VARIABLES=PreganncyInterval
    MEAN(@6a.Numberofchildrenalive)[name="MEAN__6a_Numberofchildrenalive"]
    MEAN(NumberofChildreneverborn)[name="MEAN_NumberofChildreneverborn"] MISSING=LISTWISE
    REPORTMISSING=NO
  /GRAPHSPEC SOURCE=INLINE.
BEGIN GPL
  SOURCE: s=userSource(id("graphdataset"))
  DATA: PreganncyInterval=col(source(s), name("PreganncyInterval"), unit.category())
  DATA: MEAN__6a_Numberofchildrenalive=col(source(s), name("MEAN__6a_Numberofchildrenalive"))
  DATA: MEAN_NumberofChildreneverborn=col(source(s), name("MEAN_NumberofChildreneverborn"))
  GUIDE: axis(dim(1), label("Preganncy Interval"))
  GUIDE: axis(scale(y1), label("Mean 6a.Number of children alive"), color(color."1192E8"))
  GUIDE: axis(scale(y2), label("Mean Number of Children ever born "), color(color."005D5D"),
    opposite())
  GUIDE: text.title(label("Dual Y Axes with Categorical X Axis Mean of 6a.Number of children ",
    "alive,Mean of Number of Children ever born   by Preganncy Interval"))
  SCALE: cat(dim(1), include("1", "2", "3", "4"))
  SCALE: y1 = linear(dim(2), include(0))
  SCALE: y2 = linear(dim(2), include(0))
  ELEMENT: interval(position(PreganncyInterval*MEAN__6a_Numberofchildrenalive),
    shape.interior(shape.square), color.interior(color."1192E8"), scale(y1))
  ELEMENT: line(position(PreganncyInterval*MEAN_NumberofChildreneverborn), missing.wings(),
    color.interior(color."005D5D"), scale(y2))
END GPL.
