  GUIDE: legend(aesthetic(aesthetic.color.interior), label("Country where your organization ",
    "operates ?"))
  GUIDE: text.title(label("Pie Chart Count of Country where your organization operates ?"))
  SCALE: linear(dim(1), dataMinimum(), dataMaximum())
  ELEMENT: interval.stack(position(summary.percent(COUNT))),
    color.interior(Countrywhereyourorganizationoperates))
END GPL.
