* Chart Builder.
GGRAPH
  /GRAPHDATASET NAME="graphdataset" VARIABLES=employment_duration COUNT()[name="COUNT"]
    MISSING=LISTWISE REPORTMISSING=NO
  /GRAPHSPEC SOURCE=INLINE.
BEGIN GPL
  SOURCE: s=userSource(id("graphdataset"))
  DATA: employment_duration=col(source(s), name("employment_duration"), unit.category())
  DATA: COUNT=col(source(s), name("COUNT"))
  COORD: polar.theta(startAngle(0))
  GUIDE: axis(dim(1), null())
  GUIDE: legend(aesthetic(aesthetic.color.interior), label("employment_duration"))
  GUIDE: text.title(label("Pie Chart Count of employment_duration"))
  SCALE: linear(dim(1), dataMinimum(), dataMaximum())
  ELEMENT: interval.stack(position(summary.percent(COUNT))), color.interior(employment_duration))
END GPL.
* Chart Builder.
GGRAPH
  /GRAPHDATASET NAME="graphdataset" VARIABLES=employment_duration MISSING=LISTWISE REPORTMISSING=NO
  /GRAPHSPEC SOURCE=INLINE.
BEGIN GPL
  SOURCE: s=userSource(id("graphdataset"))
  DATA: employment_duration=col(source(s), name("employment_duration"), unit.category())
  DATA: employment_duration1=col(source(s), name("employment_duration"))
  DATA: id=col(source(s), name("$CASENUM"), unit.category())
  GUIDE: axis(dim(1), label("employment_duration"))
  GUIDE: axis(dim(2), label("employment_duration"))
