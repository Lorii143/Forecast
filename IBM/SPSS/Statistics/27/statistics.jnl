* Chart Builder.
GGRAPH
  /GRAPHDATASET NAME="graphdataset" VARIABLES=see COUNT()[name="COUNT"] MISSING=LISTWISE
    REPORTMISSING=NO
  /GRAPHSPEC SOURCE=INLINE.
BEGIN GPL
  SOURCE: s=userSource(id("graphdataset"))
  DATA: see=col(source(s), name("see"), unit.category())
  DATA: COUNT=col(source(s), name("COUNT"))
  COORD: polar.theta(startAngle(0))
  GUIDE: axis(dim(1), null())
  GUIDE: legend(aesthetic(aesthetic.color.interior), label("Who did you see"))
  GUIDE: text.title(label("Pie Chart Count of Who did you see"))
  SCALE: linear(dim(1), dataMinimum(), dataMaximum())
  ELEMENT: interval.stack(position(summary.percent(COUNT))), color.interior(see))
END GPL.
