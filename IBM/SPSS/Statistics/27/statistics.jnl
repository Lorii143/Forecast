    AgeofRespnedents @6a.Numberofchildrenalive
  /PLOT NONE
  /PERCENTILES(5,10,25,50,75,90,95) HAVERAGE
  /STATISTICS DESCRIPTIVES
  /CINTERVAL 95
  /MISSING LISTWISE
  /NOTOTAL.
NOMREG PreganncyInterval (BASE=FIRST ORDER=ASCENDING) BY AgeofRespnedents MaritalStatus Religion
    EducationLevel NumberofChildreneverborn Health
  /CRITERIA CIN(95) DELTA(0) MXITER(100) MXSTEP(5) CHKSEP(20) LCONVERGE(0) PCONVERGE(0.000001)
    SINGULAR(0.00000001)
  /MODEL
  /STEPWISE=PIN(.05) POUT(0.1) MINEFFECT(0) RULE(SINGLE) ENTRYMETHOD(LR) REMOVALMETHOD(LR)
  /INTERCEPT=INCLUDE
  /PRINT=PARAMETER SUMMARY LRT CPS STEP MFI.
T-TEST GROUPS=PreganncyInterval(1 2)
  /MISSING=ANALYSIS
  /VARIABLES=AgeofRespnedents MaritalStatus Religion EducationLevel NumberofChildreneverborn
    @10.Howmuchmoneydoyouusuallyearnfromtheworkin9abovepermonth
  /ES DISPLAY(TRUE)
  /CRITERIA=CI(.95).
T-TEST GROUPS=PreganncyInterval(2 3)
  /MISSING=ANALYSIS
  /VARIABLES=AgeofRespnedents MaritalStatus Religion EducationLevel NumberofChildreneverborn
    @10.Howmuchmoneydoyouusuallyearnfromtheworkin9abovepermonth
  /ES DISPLAY(TRUE)
  /CRITERIA=CI(.95).
PARTIAL CORR
  /VARIABLES=AgeofRespnedents MaritalStatus Religion EducationLevel Health
    @10.Howmuchmoneydoyouusuallyearnfromtheworkin9abovepermonth BY PreganncyInterval
  /SIGNIFICANCE=ONETAIL
  /MISSING=LISTWISE.
