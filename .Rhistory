libs <- c("tidyverse", "dplyr",  "flextable", "glue", "scales")
for (ilib in libs) {
if (!(ilib %in% installed.packages())) {
install.packages(ilib)
}
library(ilib, character.only = TRUE)
}
Responses <- sample(c("Yes", "No", "Don't know"), size = 100, replace = TRUE,
prob = c(0.4, 0.35, 0.25))
Gender <- sample(c("Male", "Female"),  size =100, replace = TRUE)
df <- data.frame(Gen = Gender, Res = Responses)
data <- df |> group_by(Res) |> count() |> ungroup() |> mutate(Percentage = n/sum(n)) |>
arrange(Percentage) |> mutate(Percent = scales::percent(Percentage))
#----simple pie plot
ggplot(data, aes(x = "", y = Percentage, fill = Res )) +
geom_col() +
coord_polar(theta = "y")
#-----we can improve it to look better
ggplot(data, aes(x = "", y = Percentage, fill = Res)) +
geom_col() +
geom_text(aes(label = Percent),
position = position_stack(vjust = 0.5)) +
coord_polar(theta = "y")
#----------we can further make it better here
ggplot(data, aes(x = "", y = Percentage, fill = Res)) +
geom_col() +
geom_label(aes(label = Percent),
position = position_stack(vjust = 0.5),
show.legend = FALSE) +
coord_polar(theta = "y")
ggplot(data, aes(x = "", y = Percentage, fill = Res)) +
geom_col(color = "black") +
geom_label(aes(label = Percent), color = c(1, "white", "white"),
position = position_stack(vjust = 0.5),
show.legend = FALSE) +
guides(fill = guide_legend(title = "Response")) +
scale_fill_viridis_d() +
coord_polar(theta = "y") +
theme_void()
df_1 <- df |> dplyr::group_by(Res) |> tally()
flextable(df_1)
df_1 <-df_1 |>  mutate(Prop = n/sum(n)) |> mutate(Percent = scales::percent(Prop))
flextable(df_1)
# Raw data: Daily sales (in hundred thousand USD)
sales <- c(
98, 90, 85, 84, 81, 79, 76, 73, 69, 60,
98, 90, 85, 83, 80, 79, 75, 72, 68, 60,
93, 88, 85, 82, 80, 78, 75, 71, 67, 59,
93, 87, 84, 82, 79, 77, 74, 70, 64, 57,
91, 86, 84, 81, 79, 77, 74, 70, 63, 54
)
# Define class intervals
breaks <- seq(54, 99, by = 5)  # from min to just above max, width = 5
# Create frequency table
freq_table <- cut(sales, breaks = breaks, right = FALSE, include.lowest = TRUE)
table_freq <- table(freq_table)
# Convert to data frame
freq_df <- as.data.frame(table_freq)
colnames(freq_df) <- c("Class Interval", "Frequency")
# Display frequency table
print(freq_df)
